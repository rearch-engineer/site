---
/**
 * LandingFooter Component (i18n-aware)
 * Footer for landing pages with translations
 */
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
import { type Locale, defaultLocale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n/index';

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;

// Get locale from prop or infer from URL
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const links = [
  { label: t('nav.docs'), href: 'https://docs.rearch.engineer' },
  { label: t('nav.contact'), href: getLocalizedPath('contact', locale) },
  { label: t('footer.links.license'), href: getLocalizedPath('license', locale) },
];

const legalLinks = [
  { label: t('footer.legal.legalNotice'), href: getLocalizedPath('legal-notice', locale) },
  { label: t('footer.legal.privacyPolicy'), href: getLocalizedPath('privacy-policy', locale) },
  { label: t('footer.legal.license'), href: getLocalizedPath('license', locale) },
];
---

<footer class="border-border bg-background-secondary border-t py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 md:flex-row">
    <!-- Logo & Attribution -->
    <div class="flex flex-col gap-2">
      <a href={getLocalizedPath('home', locale)} class="flex items-center gap-2">
        <Logo size="sm" />
        <span class="font-display text-brand-500 text-lg font-bold">{t('site.name')}</span>
      </a>
      <p class="text-foreground-muted text-sm">{t('site.description')}</p>
    </div>

    <!-- Links -->
    <nav
      class="text-foreground-muted flex flex-wrap justify-center gap-6 text-sm font-medium md:gap-8"
    >
      {
        links.map((link) => (
          <a
            href={link.href}
            class="hover:text-foreground transition-colors"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>

  <!-- Legal Links -->
  <div
    class="border-border mx-auto mt-8 flex max-w-6xl flex-col items-center justify-between gap-4 border-t px-6 pt-8 md:flex-row"
  >
    <p class="text-foreground-muted text-sm">
      &copy; {new Date().getFullYear()}
      {t('site.name')}. All rights reserved.
    </p>
    <div class="flex items-center gap-6">
      {
        legalLinks.map((link) => (
          <a
            href={link.href}
            class="text-foreground-muted hover:text-foreground text-sm transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
