---
import '@/styles/global.css';
import SEO from '@/components/seo/SEO.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Hreflang from '@/components/i18n/Hreflang.astro';
import Analytics from '@/components/layout/Analytics.astro';
import ConsentBanner from '@/components/ui/overlay/ConsentBanner';
import { createWebsiteSchema, createOrganizationSchema } from '@/lib/schema';
import type { WebSite, Organization, WithContext } from 'schema-dts';
import siteConfig from '@/config/site.config';
import { type Locale, locales, defaultLocale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';
import type { RouteId } from '@/i18n/routes';
import { routes } from '@/i18n/routes';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    authors?: string[];
    tags?: string[];
  };
  noindex?: boolean;
  nofollow?: boolean;
  includeOrgSchema?: boolean;
  lang?: Locale;
  /**
   * Route ID for generating proper hreflang tags.
   * If provided, uses translated URLs; otherwise falls back to path-based hreflang.
   */
  routeId?: RouteId;
}

const {
  title,
  description,
  image,
  imageAlt,
  article,
  noindex = false,
  nofollow = false,
  includeOrgSchema = false,
  lang,
  routeId,
} = Astro.props;

// Get locale from props or URL path
const currentLocale = lang || getLocaleFromPath(Astro.url.pathname);

// Build translated consent UI text
const tc = useTranslations(currentLocale);
const consentUi = {
  heading: tc('consent.heading'),
  description: tc('consent.description'),
  acceptAll: tc('consent.acceptAll'),
  declineAll: tc('consent.declineAll'),
  customize: tc('consent.customize'),
  savePreferences: tc('consent.savePreferences'),
  settingsHeading: tc('consent.settingsHeading'),
  privacyPolicyLabel: tc('consent.privacyPolicyLabel'),
};
const consentAlwaysOnLabel = tc('consent.alwaysOn');

// Build JSON-LD schemas
const schemas: Array<WithContext<WebSite> | WithContext<Organization>> = [createWebsiteSchema()];
if (includeOrgSchema) {
  schemas.push(createOrganizationSchema());
}

// Build route map for browser language detection redirect script
// Maps default-locale slugs to their translated equivalents for each non-default locale
// e.g. { "es": { "": "", "about": "sobre-nosotros", "contact": "contacto", ... } }
const langRouteMap: Record<string, Record<string, string>> = {};
for (const locale of locales) {
  if (locale === defaultLocale) continue;
  const map: Record<string, string> = {};
  for (const [, slugs] of Object.entries(routes)) {
    map[slugs[defaultLocale]] = slugs[locale];
  }
  langRouteMap[locale] = map;
}
---

<!doctype html>
<html lang={currentLocale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- ReArch Fonts: Outfit (display), Manrope (body), JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking font loading -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={siteConfig.branding.favicon.svg} />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={siteConfig.branding.colors.themeColor} />

    <!-- SEO -->
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      article={article}
      noindex={noindex}
      nofollow={nofollow}
    />

    <!-- Canonical URL -->
    <link rel="canonical" href={new URL(Astro.url.pathname, siteConfig.url).toString()} />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS Feed`} href="/rss.xml" />

    <!-- Alternate language links for SEO (uses translated URLs when routeId provided) -->
    <Hreflang routeId={routeId} />

    <!-- JSON-LD Structured Data -->
    <JsonLd schema={schemas} />

    <!-- Analytics (loads if PUBLIC_GA_MEASUREMENT_ID or PUBLIC_GTM_ID is set) -->
    <Analytics />

    <!-- Browser language detection: redirect to matching locale if on default-locale page -->
    <script is:inline define:vars={{ langRouteMap, defaultLocale }}>
      (function () {
        var path = window.location.pathname.replace(/\/+$/, '') || '/';
        var segments = path.split('/').filter(Boolean);

        // Only redirect if we're on a default-locale page (no locale prefix)
        var supportedLocales = Object.keys(langRouteMap);
        if (segments.length > 0 && supportedLocales.indexOf(segments[0]) !== -1) {
          return; // Already on a non-default locale page
        }

        // Get browser languages
        var browserLangs = navigator.languages
          ? Array.prototype.slice.call(navigator.languages)
          : [navigator.language || ''];

        // Find the first matching supported locale
        var matchedLocale = null;
        for (var i = 0; i < browserLangs.length; i++) {
          var lang = browserLangs[i].toLowerCase();

          // Skip if it matches the default locale (e.g. "en", "en-US")
          if (lang === defaultLocale || lang.indexOf(defaultLocale + '-') === 0) {
            return; // Browser prefers default locale, no redirect needed
          }

          // Check exact match first (e.g. "es"), then prefix match (e.g. "es-AR" -> "es")
          if (supportedLocales.indexOf(lang) !== -1) {
            matchedLocale = lang;
            break;
          }
          var prefix = lang.split('-')[0];
          if (supportedLocales.indexOf(prefix) !== -1) {
            matchedLocale = prefix;
            break;
          }
        }

        if (!matchedLocale) return;

        var routeMap = langRouteMap[matchedLocale];
        // Current slug is the path without leading slash
        var currentSlug = segments.join('/');

        // Check if the first segment matches a known route for slug translation
        var firstSegment = segments[0] || '';
        var translatedFirstSegment = routeMap[firstSegment];

        var targetPath;
        if (currentSlug === '' || currentSlug === '/') {
          // Home page
          targetPath = '/' + matchedLocale + '/';
        } else if (translatedFirstSegment !== undefined) {
          // Known route - translate the first segment, keep the rest (e.g. blog post slugs)
          var rest = segments.slice(1).join('/');
          var translatedSlug = translatedFirstSegment;
          targetPath = '/' + matchedLocale + (translatedSlug ? '/' + translatedSlug : '');
          if (rest) {
            targetPath += '/' + rest;
          }
        } else {
          // Unknown route - just prepend the locale
          targetPath = '/' + matchedLocale + '/' + currentSlug;
        }

        // Preserve query string and hash
        window.location.replace(targetPath + window.location.search + window.location.hash);
      })();
    </script>

    <!-- Theme script (runs before render to prevent flash) -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        if (theme === 'dark' || (!theme && systemDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen bg-background text-foreground antialiased">
    <!-- Skip to content link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <slot name="header" />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <ConsentBanner ui={consentUi} alwaysOnLabel={consentAlwaysOnLabel} />
  </body>
</html>
