---
/**
 * Home/Landing Page (i18n version)
 * URL: /{lang}/ (e.g., /es/)
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import SocialProof from '@/components/ui/marketing/SocialProof/SocialProof.astro';
import TechStack from '@/components/landing/TechStack.astro';
import FeatureTabs from '@/components/landing/FeatureTabs.tsx';
import Credibility from '@/components/landing/Credibility.astro';
import CTA from '@/components/landing/CTA.astro';
import { locales, defaultLocale, isValidLocale, type Locale } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n/index';

export function getStaticPaths() {
  // Only generate paths for non-default locales
  return locales
    .filter((lang) => lang !== defaultLocale)
    .map((lang) => ({
      params: { lang },
    }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/');
}

const locale = lang as Locale;
const t = useTranslations(locale);

const ctaLink = '/cloud';
---

<LandingLayout
  title={t('hero.title') + ' ' + t('hero.titleHighlight')}
  description={t('hero.description')}
  lang={locale}
  routeId="home"
>
  <Hero layout="split" size="lg" showGrid showBlob blobPosition="right">
    <Badge slot="badge" pill pulse>{t('hero.badge')}</Badge>

    <h1 slot="title">
      {t('hero.title')}
      <span class="text-brand-500">{t('hero.titleHighlight')}</span>
    </h1>

    <p slot="description">
      {t('hero.description')}
    </p>

    <Fragment slot="actions">
      <Button size="lg" href={ctaLink}>
        {t('hero.cta')}
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button
        size="lg"
        variant="outline"
        href="https://github.com/lab34-es/rearch.engineer"
        target="_blank"
      >
        <Icon name="github" size="sm" />
        {t('hero.github')}
      </Button>
    </Fragment>

    <div
      slot="aside"
      class="bg-background-secondary/50 border-border flex min-h-[300px] flex-col items-center justify-center rounded-xl border p-8 text-center"
    >
      <Icon name="monitor" size="lg" class="text-brand-500 mb-4" />
      <p class="text-foreground-muted text-sm">Product screenshot coming soon</p>
    </div>

    <SocialProof
      class="mt-[var(--space-stack-lg)]"
      text={t('hero.socialProof')}
      avatars={[
        'https://i.pravatar.cc/150?img=12',
        'https://i.pravatar.cc/150?img=33',
        'https://i.pravatar.cc/150?img=47',
      ]}
    />
  </Hero>

  <TechStack locale={locale} />
  <FeatureTabs locale={locale} client:visible />
  <Credibility locale={locale} />
  <CTA locale={locale} />
</LandingLayout>
