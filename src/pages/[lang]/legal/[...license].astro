---
/**
 * License Page (i18n version)
 * URL: /{lang}/legal/license (en), /{lang}/legal/licencia (es)
 */
import PageLayout from '@/layouts/PageLayout.astro';
import { locales, defaultLocale, isValidLocale, type Locale } from '@/i18n/config';
import { useTranslations, routes, getLocalizedPath } from '@/i18n/index';

export function getStaticPaths() {
  const paths = [];

  for (const lang of locales) {
    if (lang === defaultLocale) continue;

    const slug = routes['license'][lang].replace('legal/', '');
    paths.push({
      params: { lang, license: slug },
    });
  }

  return paths;
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/legal/license/');
}

const locale = lang as Locale;
const t = useTranslations(locale);
const contactHref = getLocalizedPath('contact', locale);
