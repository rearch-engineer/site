---
/**
 * Legal Notice Page (i18n version)
 * URL: /{lang}/legal/legal-notice (en), /{lang}/legal/aviso-legal (es)
 */
import PageLayout from '@/layouts/PageLayout.astro';
import { locales, defaultLocale, isValidLocale, type Locale } from '@/i18n/config';
import { useTranslations, routes } from '@/i18n/index';

export function getStaticPaths() {
  const paths = [];

  for (const lang of locales) {
    if (lang === defaultLocale) continue;

    const slug = routes['legal-notice'][lang].replace('legal/', '');
    paths.push({
      params: { lang, legalNotice: slug },
    });
  }

  return paths;
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/legal/legal-notice/');
}

const locale = lang as Locale;
const t = useTranslations(locale);
---

<PageLayout
