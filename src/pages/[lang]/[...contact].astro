---
/**
 * Contact Page (i18n version)
 * URL: /{lang}/contact (en), /{lang}/contacto (es)
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import { locales, defaultLocale, isValidLocale, type Locale } from '@/i18n/config';
import { useTranslations, routes } from '@/i18n/index';

export function getStaticPaths() {
  const paths = [];

  // Generate paths for non-default locales with their translated slugs
  for (const lang of locales) {
    if (lang === defaultLocale) continue;

    const slug = routes.contact[lang];
    paths.push({
      params: { lang, contact: slug },
    });
  }

  return paths;
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/contact');
}

const locale = lang as Locale;
const t = useTranslations(locale);
---

<LandingLayout
  title={t('contact.meta.title')}
  description={t('contact.meta.description')}
  lang={locale}
  routeId="contact"
>
  <Hero layout="centered" size="sm" showGrid>
    <h1 slot="title">
      {t('contact.hero.title')}
      <span class="text-brand-500">{t('contact.hero.titleHighlight')}</span>
    </h1>

    <p slot="description">
      {t('contact.hero.description')}
    </p>
  </Hero>

  <!-- Contact Info Section -->
  <section class="bg-surface-secondary py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="font-display text-foreground mb-8 text-center text-2xl font-bold">
        {t('contact.info.title')}
      </h2>

      <div class="grid gap-6 sm:grid-cols-2">
        <!-- Email -->
        <a href={`mailto:${siteConfig.email}`} class="block">
          <Card hover padding="lg">
            <div class="flex flex-col items-center gap-3 text-center">
              <div
                class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br"
              >
                <Icon name="mail" size="md" />
              </div>
              <div>
                <p class="text-foreground font-medium">{t('contact.info.email.label')}</p>
                <p class="text-foreground-muted text-sm">{siteConfig.email}</p>
              </div>
            </div>
          </Card>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/rearch-engineer"
          target="_blank"
          rel="noopener noreferrer"
          class="block"
        >
          <Card hover padding="lg">
            <div class="flex flex-col items-center gap-3 text-center">
              <div
                class="from-brand-500/20 to-brand-500/5 text-brand-500 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br"
              >
                <Icon name="github" size="md" />
              </div>
              <div>
                <p class="text-foreground font-medium">{t('contact.info.github.label')}</p>
                <p class="text-foreground-muted text-sm">github.com/rearch-engineer</p>
              </div>
            </div>
          </Card>
        </a>


      </div>
    </div>
  </section>
</LandingLayout>
